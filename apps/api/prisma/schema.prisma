// ERP 全家桶 - Prisma Schema
// Database: PostgreSQL 16
// Multi-tenancy: Schema-per-Tenant

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PUBLIC SCHEMA - Shared across all tenants
// ============================================================

enum TenantPlan {
  starter
  professional
  enterprise
  custom
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

enum UserStatus {
  active
  inactive
  locked
  pending_verification
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
}

model Tenant {
  id                    String       @id @default(uuid()) @db.Uuid
  code                  String       @unique @db.VarChar(20)
  name                  String       @db.VarChar(200)
  nameEn                String?      @map("name_en") @db.VarChar(200)
  logoUrl               String?      @map("logo_url")
  plan                  TenantPlan   @default(starter)
  status                TenantStatus @default(trial)
  schemaName            String       @unique @map("schema_name") @db.VarChar(63)
  modules               Json         @default("[]")
  settings              Json         @default("{}")
  maxUsers              Int          @default(5) @map("max_users")
  trialEndsAt           DateTime?    @map("trial_ends_at") @db.Timestamptz
  subscriptionStartsAt  DateTime?    @map("subscription_starts_at") @db.Timestamptz
  subscriptionEndsAt    DateTime?    @map("subscription_ends_at") @db.Timestamptz
  contactEmail          String       @map("contact_email") @db.VarChar(254)
  contactPhone          String?      @map("contact_phone") @db.VarChar(50)
  country               String       @default("TW") @db.VarChar(2)
  timezone              String       @default("Asia/Taipei") @db.VarChar(50)
  locale                String       @default("zh-TW") @db.VarChar(10)
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?    @map("deleted_at") @db.Timestamptz

  users      User[]
  roles      Role[]
  auditLogs  AuditLog[]

  @@map("tenants")
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  tenantId            String?    @map("tenant_id") @db.Uuid
  email               String     @db.VarChar(254)
  passwordHash        String     @map("password_hash") @db.VarChar(255)
  displayName         String     @map("display_name") @db.VarChar(100)
  avatarUrl           String?    @map("avatar_url")
  status              UserStatus @default(pending_verification)
  isSuperAdmin        Boolean    @default(false) @map("is_super_admin")
  locale              String     @default("zh-TW") @db.VarChar(10)
  timezone            String     @default("Asia/Taipei") @db.VarChar(50)
  twoFaEnabled        Boolean    @default(false) @map("two_fa_enabled")
  twoFaSecret         String?    @map("two_fa_secret") @db.VarChar(255)
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz
  lastLoginIp         String?    @map("last_login_ip")
  failedLoginCount    Int        @default(0) @map("failed_login_count")
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz
  emailVerifiedAt     DateTime?  @map("email_verified_at") @db.Timestamptz
  passwordChangedAt   DateTime?  @map("password_changed_at") @db.Timestamptz
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  nameEn      String?  @map("name_en") @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(100)
  module      String   @db.VarChar(50)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String?     @map("tenant_id") @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  module     String?     @db.VarChar(50)
  resource   String?     @db.VarChar(100)
  resourceId String?     @map("resource_id") @db.VarChar(255)
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ============================================================
// TENANT SCHEMA MODELS
// These are created per-tenant schema via tenant-schema-init.sql
// Prisma client routes to the correct schema using SET LOCAL search_path
// ============================================================

// ----- SALES MODULE -----

model Customer {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique @db.VarChar(20)
  name          String    @db.VarChar(200)
  nameEn        String?   @map("name_en") @db.VarChar(200)
  taxId         String?   @map("tax_id") @db.VarChar(20)
  creditLimit   Decimal   @default(0) @map("credit_limit") @db.Decimal(15, 2)
  creditBalance Decimal   @default(0) @map("credit_balance") @db.Decimal(15, 2)
  paymentTerms  Int       @default(30) @map("payment_terms")
  grade         String    @default("C") @db.VarChar(1)
  contactName   String?   @map("contact_name") @db.VarChar(100)
  contactPhone  String?   @map("contact_phone") @db.VarChar(50)
  contactEmail  String?   @map("contact_email") @db.VarChar(254)
  address       String?
  city          String?   @db.VarChar(100)
  country       String    @default("TW") @db.VarChar(2)
  currency      String    @default("TWD") @db.VarChar(3)
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  salesOrders SalesOrder[]

  @@map("customers")
}

model SalesOrder {
  id              String    @id @default(uuid()) @db.Uuid
  orderNo         String    @unique @map("order_no") @db.VarChar(30)
  customerId      String    @map("customer_id") @db.Uuid
  status          String    @default("draft") @db.VarChar(30)
  orderDate       DateTime  @map("order_date") @db.Date
  requestedDate   DateTime? @map("requested_date") @db.Date
  shippingAddress String?   @map("shipping_address")
  currency        String    @default("TWD") @db.VarChar(3)
  exchangeRate    Decimal   @default(1) @map("exchange_rate") @db.Decimal(10, 6)
  subtotal        Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  total           Decimal   @default(0) @db.Decimal(15, 2)
  creditChecked   Boolean   @default(false) @map("credit_checked")
  notes           String?
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  createdBy       String    @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  customer       Customer         @relation(fields: [customerId], references: [id])
  lines          SalesOrderLine[]
  deliveryOrders DeliveryOrder[]

  @@map("sales_orders")
}

model SalesOrderLine {
  id         String  @id @default(uuid()) @db.Uuid
  soId       String  @map("so_id") @db.Uuid
  lineNo     Int     @map("line_no")
  itemCode   String  @map("item_code") @db.VarChar(30)
  itemName   String  @map("item_name") @db.VarChar(200)
  spec       String? @db.VarChar(200)
  unit       String  @db.VarChar(20)
  quantity   Decimal @db.Decimal(15, 4)
  unitPrice  Decimal @map("unit_price") @db.Decimal(15, 4)
  discount   Decimal @default(0) @db.Decimal(5, 2)
  amount     Decimal @db.Decimal(15, 2)
  shippedQty Decimal @default(0) @map("shipped_qty") @db.Decimal(15, 4)
  notes      String?

  order SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)

  @@unique([soId, lineNo])
  @@map("so_lines")
}

model DeliveryOrder {
  id         String    @id @default(uuid()) @db.Uuid
  doNo       String    @unique @map("do_no") @db.VarChar(30)
  soId       String    @map("so_id") @db.Uuid
  status     String    @default("draft") @db.VarChar(20)
  shipDate   DateTime? @map("ship_date") @db.Date
  carrier    String?   @db.VarChar(100)
  trackingNo String?   @map("tracking_no") @db.VarChar(100)
  notes      String?
  createdBy  String    @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  order     SalesOrder @relation(fields: [soId], references: [id])

  @@map("delivery_orders")
}

// ----- PROCUREMENT MODULE -----

model Supplier {
  id             String    @id @default(uuid()) @db.Uuid
  code           String    @unique @db.VarChar(20)
  name           String    @db.VarChar(200)
  nameEn         String?   @map("name_en") @db.VarChar(200)
  taxId          String?   @map("tax_id") @db.VarChar(20)
  paymentTerms   Int       @default(30) @map("payment_terms")
  grade          String    @default("C") @db.VarChar(1)
  contactName    String?   @map("contact_name") @db.VarChar(100)
  contactPhone   String?   @map("contact_phone") @db.VarChar(50)
  contactEmail   String?   @map("contact_email") @db.VarChar(254)
  address        String?
  city           String?   @db.VarChar(100)
  country        String    @default("TW") @db.VarChar(2)
  currency       String    @default("TWD") @db.VarChar(3)
  bankName       String?   @map("bank_name") @db.VarChar(100)
  bankAccount    String?   @map("bank_account") @db.VarChar(50)
  isActive       Boolean   @default(true) @map("is_active")
  notes          String?
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseRequisition {
  id            String    @id @default(uuid()) @db.Uuid
  prNo          String    @unique @map("pr_no") @db.VarChar(30)
  status        String    @default("draft") @db.VarChar(30)
  requestDate   DateTime  @map("request_date") @db.Date
  requiredDate  DateTime? @map("required_date") @db.Date
  department    String?   @db.VarChar(100)
  purpose       String?
  notes         String?
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at") @db.Timestamptz
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  lines          PRLine[]
  purchaseOrders PurchaseOrder[]

  @@map("purchase_requisitions")
}

model PRLine {
  id          String   @id @default(uuid()) @db.Uuid
  prId        String   @map("pr_id") @db.Uuid
  lineNo      Int      @map("line_no")
  itemCode    String   @map("item_code") @db.VarChar(30)
  itemName    String   @map("item_name") @db.VarChar(200)
  spec        String?  @db.VarChar(200)
  unit        String   @db.VarChar(20)
  quantity    Decimal  @db.Decimal(15, 4)
  notes       String?

  pr PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@unique([prId, lineNo])
  @@map("pr_lines")
}

model PurchaseOrder {
  id            String    @id @default(uuid()) @db.Uuid
  poNo          String    @unique @map("po_no") @db.VarChar(30)
  supplierId    String    @map("supplier_id") @db.Uuid
  prId          String?   @map("pr_id") @db.Uuid
  status        String    @default("draft") @db.VarChar(30)
  orderDate     DateTime  @map("order_date") @db.Date
  expectedDate  DateTime? @map("expected_date") @db.Date
  currency      String    @default("TWD") @db.VarChar(3)
  exchangeRate  Decimal   @default(1) @map("exchange_rate") @db.Decimal(10, 6)
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  total         Decimal   @default(0) @db.Decimal(15, 2)
  notes         String?
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at") @db.Timestamptz
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  pr            PurchaseRequisition? @relation(fields: [prId], references: [id])
  lines         POLine[]
  goodsReceipts GoodsReceipt[]

  @@map("purchase_orders")
}

model POLine {
  id           String  @id @default(uuid()) @db.Uuid
  poId         String  @map("po_id") @db.Uuid
  lineNo       Int     @map("line_no")
  itemCode     String  @map("item_code") @db.VarChar(30)
  itemName     String  @map("item_name") @db.VarChar(200)
  spec         String? @db.VarChar(200)
  unit         String  @db.VarChar(20)
  quantity     Decimal @db.Decimal(15, 4)
  unitPrice    Decimal @map("unit_price") @db.Decimal(15, 4)
  amount       Decimal @db.Decimal(15, 2)
  receivedQty  Decimal @default(0) @map("received_qty") @db.Decimal(15, 4)
  notes        String?

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@unique([poId, lineNo])
  @@map("po_lines")
}

model GoodsReceipt {
  id          String    @id @default(uuid()) @db.Uuid
  grNo        String    @unique @map("gr_no") @db.VarChar(30)
  poId        String    @map("po_id") @db.Uuid
  status      String    @default("draft") @db.VarChar(20)
  receiveDate DateTime  @map("receive_date") @db.Date
  notes       String?
  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  po    PurchaseOrder  @relation(fields: [poId], references: [id])
  lines GRLine[]

  @@map("goods_receipts")
}

model GRLine {
  id           String  @id @default(uuid()) @db.Uuid
  grId         String  @map("gr_id") @db.Uuid
  poLineId     String  @map("po_line_id") @db.Uuid
  lineNo       Int     @map("line_no")
  itemCode     String  @map("item_code") @db.VarChar(30)
  itemName     String  @map("item_name") @db.VarChar(200)
  unit         String  @db.VarChar(20)
  orderedQty   Decimal @map("ordered_qty") @db.Decimal(15, 4)
  receivedQty  Decimal @map("received_qty") @db.Decimal(15, 4)
  notes        String?

  gr GoodsReceipt @relation(fields: [grId], references: [id], onDelete: Cascade)

  @@unique([grId, lineNo])
  @@map("gr_lines")
}

// ----- INVENTORY MODULE -----

model Item {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  category      String?
  unit          String   @default("PCS")
  unitCost      Decimal  @default(0) @map("unit_cost") @db.Decimal(15, 4)
  safetyStock   Decimal  @default(0) @map("safety_stock") @db.Decimal(15, 4)
  reorderPoint  Decimal  @default(0) @map("reorder_point") @db.Decimal(15, 4)
  isActive      Boolean  @default(true) @map("is_active")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  stockLevels  StockLevel[]
  transactions StockTransaction[]
  countLines   StockCountLine[]

  @@map("items")
}

model Warehouse {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  location    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  stockLevels  StockLevel[]
  transactions StockTransaction[]
  stockCounts  StockCount[]

  @@map("warehouses")
}

model StockLevel {
  id          String    @id @default(cuid())
  itemId      String    @map("item_id")
  warehouseId String    @map("warehouse_id")
  quantity    Decimal   @default(0) @db.Decimal(15, 4)
  reservedQty Decimal   @default(0) @map("reserved_qty") @db.Decimal(15, 4)
  updatedAt   DateTime  @updatedAt @map("updated_at")

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
  @@map("stock_levels")
}

model StockTransaction {
  id          String   @id @default(cuid())
  txnNo       String   @unique @map("txn_no")
  itemId      String   @map("item_id")
  warehouseId String   @map("warehouse_id")
  txnType     String   @map("txn_type")
  quantity    Decimal  @db.Decimal(15, 4)
  unitCost    Decimal  @default(0) @map("unit_cost") @db.Decimal(15, 4)
  refDocType  String?  @map("ref_doc_type")
  refDocId    String?  @map("ref_doc_id")
  refDocNo    String?  @map("ref_doc_no")
  notes       String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("stock_transactions")
}

model StockCount {
  id          String    @id @default(cuid())
  countNo     String    @unique @map("count_no")
  warehouseId String    @map("warehouse_id")
  status      String    @default("draft")
  countDate   DateTime  @map("count_date")
  notes       String?
  createdBy   String?   @map("created_by")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  lines     StockCountLine[]

  @@map("stock_counts")
}

model StockCountLine {
  id           String   @id @default(cuid())
  stockCountId String   @map("stock_count_id")
  itemId       String   @map("item_id")
  systemQty    Decimal  @map("system_qty") @db.Decimal(15, 4)
  countedQty   Decimal? @map("counted_qty") @db.Decimal(15, 4)
  variance     Decimal? @db.Decimal(15, 4)
  notes        String?

  stockCount StockCount @relation(fields: [stockCountId], references: [id])
  item       Item       @relation(fields: [itemId], references: [id])

  @@map("stock_count_lines")
}
