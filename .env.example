# ============================================================
# ERP 全家桶 - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
NODE_ENV=development
APP_PORT=3001
WEB_PORT=3000

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=erp_fullhouse
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password_change_me
DATABASE_URL=postgresql://erp_user:erp_password_change_me@localhost:5432/erp_fullhouse?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me
REDIS_URL=redis://:redis_password_change_me@localhost:6379

# --- MinIO ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key_change_me
MINIO_BUCKET_NAME=erp-files
MINIO_USE_SSL=false

# --- JWT ---
JWT_SECRET=your_jwt_secret_at_least_32_chars_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_chars_change_me
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@erp-fullhouse.com

# --- Super Admin (seeded on first run) ---
SUPER_ADMIN_EMAIL=admin@erp-fullhouse.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# --- Feature Flags ---
ENABLE_2FA=true
ENABLE_AUDIT_LOG=true
