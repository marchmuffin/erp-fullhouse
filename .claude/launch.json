{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (NestJS)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@erp-fullhouse/api", "dev"],
      "port": 4001
    },
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@erp-fullhouse/web", "dev"],
      "port": 4000
    },
    {
      "name": "Docker (PostgreSQL + Redis + MinIO + PgBouncer)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 5432
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@erp-fullhouse/api", "prisma:studio"],
      "port": 5555
    }
  ]
}
